# ─────────────────────────────────────────────────────────────
# ATS Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ats_db

# ── Auth Mode ──────────────────────────────────────────────────
# Use 'mock' for local development, 'keycloak' for production
AUTH_PROVIDER=mock

# ── Platform SUPER_ADMIN (mock mode only) ──────────────────────
# These credentials are used ONCE on first boot to create the
# platform super admin. After that, the DB is the source of truth.
PLATFORM_ADMIN_EMAIL=admin@enfycon.com
PLATFORM_ADMIN_PASSWORD=ChangeMe_StrongPassword!99
PLATFORM_ADMIN_NAME=Enfy Super Admin

# ── Default Tenant (your master tenant) ────────────────────────
DEFAULT_TENANT_ID=d3b07384-d113-49c3-a555-9ee75c13ca33

# ── JWT (mock mode only) ───────────────────────────────────────
# Change this to a long random string in production
MOCK_JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── Keycloak (when AUTH_PROVIDER=keycloak) ─────────────────────
# KEYCLOAK_ISSUER=https://your-keycloak.com/realms/ats
# KEYCLOAK_CLIENT_ID=ats-backend
# KEYCLOAK_CLIENT_SECRET=your-client-secret
# KEYCLOAK_PUBLIC_KEY=your-rsa-public-key

# ── App ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
